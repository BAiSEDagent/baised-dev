// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Core intel persistence layer for agentic updates
model IntelPost {
  id           String   @id @default(cuid())
  timestamp    DateTime @default(now())
  blockHeight  Int
  intelPayload Json     // Native JSONB in Postgres
  signature    String   // Agent signature for integrity verification
  category     String   @default("general") // ecosystem, security, devlog, alert
  status       String   @default("published") // published, draft, retracted
  isPremium    Boolean  @default(false)
  priceUsdc    String?  // e.g. "2.50" — null for free posts
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([timestamp])
  @@index([category])
  @@index([blockHeight])
  @@map("intel_posts")
}

/// x402 payment ledger — tracks USDC payments for gated intel access
model PaymentLedger {
  id            String   @id @default(cuid())
  txHash        String   @unique // Onchain USDC transfer tx hash (replay protection)
  payer         String   // Sender address (checksummed)
  amount        String   // Payment amount in wei (string to avoid BigInt precision loss)
  blockNumber   Int      // Block the tx was mined in
  verifiedAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([payer])
  @@index([txHash])
  @@map("payment_ledger")
}

/// AI Agent Directory — curated registry of agents building on Base
model Agent {
  id            String   @id @default(cuid())
  name          String
  description   String
  category      String   // trading, defi, social, infrastructure, devrel, analytics, other
  capabilities  String[] // e.g. ["swaps", "bridging", "lending", "content", "analytics"]
  walletAddress String?  // Base mainnet address (optional)
  website       String?
  twitter       String?
  github        String?
  cdpTools      String[] // e.g. ["agentkit", "server-wallet", "x402", "onchainkit"]
  builder       String?  // Team or individual name
  status        String   @default("pending") // pending, approved, rejected
  featured      Boolean  @default(false)
  submitterIp   String?  // For moderation/anti-spam tracking
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
  @@index([status])
  @@map("agents")
}
