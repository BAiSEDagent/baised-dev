// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Core intel persistence layer for agentic updates
model IntelPost {
  id           String   @id @default(cuid())
  timestamp    DateTime @default(now())
  blockHeight  Int
  intelPayload Json     // Native JSONB in Postgres
  signature    String   // Agent signature for integrity verification
  category     String   @default("general") // ecosystem, security, devlog, alert
  status       String   @default("published") // published, draft, retracted
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([timestamp])
  @@index([category])
  @@index([blockHeight])
  @@map("intel_posts")
}

/// x402 payment ledger — tracks USDC payments for gated intel access
model PaymentLedger {
  id            String   @id @default(cuid())
  txHash        String   @unique // Onchain USDC transfer tx hash (replay protection)
  payer         String   // Sender address (checksummed)
  amount        String   // Payment amount in wei (string to avoid BigInt precision loss)
  blockNumber   Int      // Block the tx was mined in
  verifiedAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([payer])
  @@index([txHash])
  @@map("payment_ledger")
}
